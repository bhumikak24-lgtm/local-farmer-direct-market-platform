{
  "name": "local-farmer-direct-market-platform",
  "version": "1.0.0",
  "description": "Local Farmer Direct Market Platform - Compliance Suite",
  "main": "index.js",
  "scripts": {
    "prepare": "husky install",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --audit-level=high",
    "security": "gitleaks detect --source . --verbose",
    "changelog": "git-cliff -o CHANGELOG.md",
    "validate": "npm run lint && npm run format && npm run typecheck && npm run test && npm run security"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@oxlint/cli": "^0.15.13",
    "@vitest/coverage-v8": "^3.0.7",
    "biome": "^1.9.4",
    "eslint": "^9.21.0",
    "eslint-plugin-react": "^7.37.4",
    "git-cliff": "^2.8.1",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "knip": "^5.45.0",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.2",
    "vitest": "^3.0.7"
  }
}
